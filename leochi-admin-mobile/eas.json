{
  "cli": {
    "version": ">= 10.0.0"
  },
  "build": {
    "owner-dev": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "APP_VARIANT": "owner-dev"
      }
    },
    "owner-internal": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "APP_VARIANT": "owner-internal"
      }
    },
    "owner-prod": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "APP_VARIANT": "owner-prod"
      }
    }
  }
}
